# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase Credentials
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Encryption Key (32-character string used to encrypt/decrypt certificate passwords in DB)
ENCRYPTION_KEY=d7b9f874287e02e1c9441113bcf3d842

# Fiscal API Integration Configuration
# Set to 'true' to run fully simulated integration without real Serpro certs/credentials
MOCK_FISCAL_API=true

# Serpro / National NFS-e API Credentials (Real Environment)
SERPRO_API_URL=https://homologacao.nfse.gov.br/api/v1
SERPRO_CLIENT_ID=your_client_id
SERPRO_CLIENT_SECRET=your_client_secret

# Background Workers Control
# Auto-starts workers inside the Express instance (recommended for simple Render deployments)
START_BACKGROUND_WORKERS=true
